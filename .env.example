# Legacy auth settings. Runtime auth/JWT is disabled; these are kept only so
# existing local databases and future role-based auth restoration have defaults.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=12345678
USER_USERNAME=user
USER_PASSWORD=12345678
JWT_SECRET=replace-with-a-long-random-secret

# Backend
APP_ENV=development
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:8080
DATABASE_URL=sqlite+aiosqlite:///./data/app.db
REDIS_URL=redis://localhost:6379/0

# OpenAI-compatible models
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=replace-me
CHAT_MODEL=gpt-4o
MEMORY_MODEL=gpt-4o-mini
GRAPH_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072

# Media-assisted child observation VLM.
# Moonshot/Kimi K2.6 example. These override only child observation vision analysis.
MULTIMODAL_BASE_URL=https://api.moonshot.cn/v1
MULTIMODAL_API_KEY=replace-me
MULTIMODAL_MODEL_NAME=kimi-k2.6
MULTIMODAL_ASR_MODEL_NAME=FunAudioLLM/SenseVoiceSmall
MULTIMODAL_REQUEST_TIMEOUT_SECONDS=240
MULTIMODAL_MAX_UPLOAD_BYTES=268435456
MULTIMODAL_JOB_BATCH_SIZE=8
MULTIMODAL_FRAME_INTERVAL_SECONDS=1
MULTIMODAL_FRAME_BATCH_SIZE=1
MULTIMODAL_CONTACT_SHEET_FRAMES_PER_SHEET=4
MULTIMODAL_CONTACT_SHEET_MAX_SHEETS_PER_VIDEO=1
MULTIMODAL_MODEL_AGGREGATION_ENABLED=false
MULTIMODAL_ALLOW_DETERMINISTIC_FALLBACK=false
MULTIMODAL_AUDIO_ANALYSIS_ENABLED=false
MULTIMODAL_RATE_LIMIT_RETRY_DELAYS_SECONDS=10,30,60

# Local services
LETTA_BASE_URL=http://localhost:8283
LETTA_API_KEY=
LETTA_SERVER_PASSWORD=local-letta-password
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=letmemgraph
QDRANT_URL=http://localhost:6333
LIGHTRAG_BASE_URL=http://localhost:9621
LIGHTRAG_API_KEY=local-lightrag-key

# Social simulation
SIMULATION_STEP_MINUTES=15
SIMULATION_MAX_AGENTS_PER_STEP=2
SIMULATION_SNAPSHOT_INTERVAL=5
SIMULATION_WORKER_INTERVAL_SECONDS=5
SIMULATION_CONCORDIA_ENABLED=true
SIMULATION_USE_LETTA_ACTIONS=false
SIMULATION_CONCORDIA_MAX_TOKENS=1200
