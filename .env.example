# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now
USER_USERNAME=user
USER_PASSWORD=change-me-now
JWT_SECRET=replace-with-a-long-random-secret

# Backend
APP_ENV=development
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:8080
DATABASE_URL=sqlite+aiosqlite:///./data/app.db
REDIS_URL=redis://localhost:6379/0

# OpenAI-compatible models
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=replace-me
CHAT_MODEL=gpt-4o
MEMORY_MODEL=gpt-4o-mini
GRAPH_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072

# Local services
LETTA_BASE_URL=http://localhost:8283
LETTA_API_KEY=
LETTA_SERVER_PASSWORD=local-letta-password
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=letmemgraph
QDRANT_URL=http://localhost:6333
LIGHTRAG_BASE_URL=http://localhost:9621
LIGHTRAG_API_KEY=local-lightrag-key

# Social simulation
SIMULATION_STEP_MINUTES=15
SIMULATION_MAX_AGENTS_PER_STEP=2
SIMULATION_SNAPSHOT_INTERVAL=5
SIMULATION_WORKER_INTERVAL_SECONDS=5
SIMULATION_CONCORDIA_ENABLED=true
SIMULATION_USE_LETTA_ACTIONS=false
SIMULATION_CONCORDIA_MAX_TOKENS=1200
